// ==================================================================================
// RF MODEL UNCERTAINTY ANALYSIS - Based on SD to RMSE Calibration Workflow
// ==================================================================================
// This script implements the uncertainty analysis workflow from the document:
// Step 1: Aggregate pixels to FIA hexagons (Mean SD, Absolute Error, RMSE)
// Step 2: Export data for linear regression (SD vs RMSE calibration) in Python
// Step 3: Apply calibration to create Expected Error Map
// ==================================================================================

// load model output after uploading to assets
var rfmodelBiomass = image;  

// you need to also load the ensemble SD raster from your RF model
// this should be the standard deviation across all trees
var rfEnsembleSD = image2;  

// convert model output from lbs/acre to Mg/ha
var conversionFactor = 0.00112085;
var rfmodelMgHa = rfmodelBiomass.multiply(conversionFactor).rename('rf_model_biomass_Mg_ha');

// ensure the SD file is also in Mg/ha
var rfEnsembleSD_MgHa = rfEnsembleSD.multiply(conversionFactor).rename('rf_ensemble_sd_Mg_ha');

// define study area
var ecoregions = ee.FeatureCollection("RESOLVE/ECOREGIONS/2017");
var edPlateau = ecoregions.filter(ee.Filter.eq('ECO_NAME', 'Edwards Plateau savanna'));

// clip
var rfmodelMgHa = rfmodelMgHa.clip(edPlateau);
var rfEnsembleSD_MgHa = rfEnsembleSD_MgHa.clip(edPlateau);

// define CRS
var targetCRS = 'EPSG:32614';

// ----- set up NLCD forest mask -----
var nlcd_landcover = ee.ImageCollection("projects/sat-io/open-datasets/USGS/ANNUAL_NLCD/LANDCOVER");
var forestClasses = [41, 42, 43, 52];

function createForestMask(image) {
  var forestMask = image.remap(forestClasses, ee.List([1, 1, 1, 1]), 0);
  return forestMask.updateMask(forestMask.neq(0));
}

var latestLandCover = nlcd_landcover.sort('system:time_start', false).first();
var forestMask = createForestMask(latestLandCover).clip(edPlateau);

// apply forest mask to both rasters
var rfmodelMgHa_masked = rfmodelMgHa.updateMask(forestMask);
var rfEnsembleSD_masked = rfEnsembleSD_MgHa.updateMask(forestMask);

// ----- load FIA hexagon data -----
var fiaData = table;

// filter FIA hexagons to study area
var fiaClipped = fiaData.filterBounds(edPlateau.geometry())
  .map(function(feature) {
    return feature.set('contained', edPlateau.geometry().contains(feature.geometry()));
  })
  .filter(ee.Filter.eq('contained', true));

print('Total FIA hexagons in Edwards Plateau:', fiaClipped.size());

// ==================================================================================
// STEP 1: AGGREGATE PIXELS TO FIA HEXAGONS
// ==================================================================================

// ----- 1.1: Calculate Mean Ensemble SD per Hexagon (σ̄_h) -----
// This is the average internal model disagreement across all 30m pixels within each hexagon

var meanSDPerHexagon = rfEnsembleSD_masked.reduceRegions({
  collection: fiaClipped,
  reducer: ee.Reducer.mean().setOutputs(['mean_ensemble_sd']),
  scale: 30,
  crs: targetCRS,
  tileScale: 8
});

// ----- 1.2: Calculate Mean Predicted AGBD per Hexagon (Ŷ_h) -----
var meanPredPerHexagon = rfmodelMgHa_masked.reduceRegions({
  collection: fiaClipped,
  reducer: ee.Reducer.mean().setOutputs(['mean_predicted_agbd']),
  scale: 30,
  crs: targetCRS,
  tileScale: 8
});

// ----- 1.3: Calculate Pixel Count per Hexagon (n_h) -----
var pixelCountPerHexagon = rfmodelMgHa_masked.reduceRegions({
  collection: fiaClipped,
  reducer: ee.Reducer.count().setOutputs(['pixel_count']),
  scale: 30,
  crs: targetCRS,
  tileScale: 8
});

// ----- Combine all hexagon-level statistics -----
// first, stack the RF predictions and ensemble SD for combined reduction
var rfStack = ee.Image.cat([
  rfmodelMgHa_masked.rename('rf_pred'),
  rfEnsembleSD_masked.rename('rf_sd')
]);

// reduce to get mean prediction and mean SD per hexagon
var hexagonStats = rfStack.reduceRegions({
  collection: fiaClipped,
  reducer: ee.Reducer.mean(),
  scale: 30,
  crs: targetCRS,
  tileScale: 8
});

// ----- Calculate Actual Absolute Error (|ε_h|) and RMSE per Hexagon -----
// we need to calculate RMSE at the pixel level relative to FIA value

// function to calculate hexagon-level metrics
var calculateHexagonMetrics = function(hexagon) {
  var geometry = hexagon.geometry();
  
  // get FIA observed value (CRM_LIVE in Mg/ha)
  var fiaValue = ee.Number.parse(hexagon.get('CRM_LIVE'));
  
  // get mean predicted AGBD
  var meanPred = ee.Number(hexagon.get('rf_pred'));
  
  // get mean ensemble SD
  var meanSD = ee.Number(hexagon.get('rf_sd'));
  
  // calculate abs error
  var absError = meanPred.subtract(fiaValue).abs();
  
  // for RMSE, we need to calculate pixel-level squared differences
  // RMSE_h = sqrt(mean((x_i - Y_h)^2))
  var fiaImage = ee.Image.constant(fiaValue);
  var squaredDiff = rfmodelMgHa_masked.subtract(fiaImage).pow(2);
  
  var mse = squaredDiff.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: geometry,
    scale: 30,
    maxPixels: 1e9
  }).get('rf_model_biomass_Mg_ha');
  
  var rmse = ee.Number(mse).sqrt();
  
  // get pixel count
  var pixelCount = rfmodelMgHa_masked.reduceRegion({
    reducer: ee.Reducer.count(),
    geometry: geometry,
    scale: 30,
    maxPixels: 1e9
  }).get('rf_model_biomass_Mg_ha');
  
  return hexagon.set({
    'FIA_observed': fiaValue,
    'mean_predicted': meanPred,
    'mean_ensemble_sd': meanSD,
    'absolute_error': absError,
    'hexagon_rmse': rmse,
    'pixel_count': pixelCount
  });
};

// filter for valid hexagons first
var validHexagons = hexagonStats
  .filter(ee.Filter.notNull(['CRM_LIVE', 'rf_pred', 'rf_sd']))
  .filter(ee.Filter.neq('rf_pred', null))
  .filter(ee.Filter.neq('rf_sd', null));

// map the calculation function
var hexagonsWithMetrics = validHexagons.map(calculateHexagonMetrics);

// filter out any null results
var hexagonsComplete = hexagonsWithMetrics.filter(
  ee.Filter.and(
    ee.Filter.notNull(['mean_ensemble_sd', 'hexagon_rmse', 'absolute_error']),
    ee.Filter.gt('pixel_count', 0)
  )
);

